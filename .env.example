# PowerplAI Environment Configuration
# Copy to .env and fill in required values

# =============================================================================
# REQUIRED
# =============================================================================

# Anthropic API Key (for Claude LLM)
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# DATABASE
# =============================================================================

# PostgreSQL connection string (default works with docker-compose)
DATABASE_URL=postgresql+asyncpg://powerplai:powerplai_dev@localhost:5432/powerplai

# For production (Railway), this is auto-provided as DATABASE_URL
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Debug mode (enables verbose logging, allows all CORS origins)
DEBUG=true

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable automatic data updates on startup
AUTO_UPDATE_ENABLED=true

# =============================================================================
# DATA SOURCES (all have defaults, no auth required)
# =============================================================================

# NHL Official API (no auth needed)
NHL_API_BASE=https://api-web.nhle.com/v1
NHL_STATS_API_BASE=https://api.nhle.com/stats/rest/en

# ChromaDB (optional, for alternative vector storage)
CHROMA_HOST=localhost
CHROMA_PORT=8001

# The Odds API - Live sportsbook odds for betting analysis
# Get free key at: https://the-odds-api.com (500 requests/month free)
# ODDS_API_KEY=your_key_here

# =============================================================================
# CORS (Production)
# =============================================================================

# Comma-separated list of allowed origins (for production)
# CORS_ORIGINS=https://your-frontend.vercel.app,https://your-domain.com

# =============================================================================
# FRONTEND (Next.js)
# =============================================================================

# Backend API URL (for frontend to call)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Enable demo mode (uses cached data, no backend required)
# NEXT_PUBLIC_DEMO_MODE=true

# Base path for GitHub Pages deployment
# NEXT_PUBLIC_BASE_PATH=/powerplai
